rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- OBJECTS ---
    function isValidObjectBase(data) {
      return data.keys().hasAll(['objectId', 'ownerId', 'createdAt', 'updatedAt'])
        && data.objectId is string && data.objectId.size() <= 128
        && data.ownerId == request.auth.uid
        && (data.get('name', '') is string && data.get('name', '').size() <= 200)
        && (data.get('description', '') is string && data.get('description', '').size() <= 2000)
        && data.get('status', 'active') in ['active', 'archived', 'lost', 'disposed']
        && (!('currentLocation' in data) || (data.currentLocation is map && 'latitude' in data.currentLocation && data.currentLocation.latitude is number && data.currentLocation.latitude >= -90 && data.currentLocation.latitude <= 90 && 'longitude' in data.currentLocation && data.currentLocation.longitude is number && data.currentLocation.longitude >= -180 && data.currentLocation.longitude <= 180 && (!('address' in data.currentLocation) || (data.currentLocation.address is string && data.currentLocation.address.size() <= 1000)) && (!('updatedAt' in data.currentLocation) || data.currentLocation.updatedAt is timestamp)))
        && (!('identifierSummary' in data) || (data.identifierSummary is map && 'activeKinds' in data.identifierSummary && data.identifierSummary.activeKinds is list && 'activeIdentifierCount' in data.identifierSummary && data.identifierSummary.activeIdentifierCount is number && data.identifierSummary.activeIdentifierCount >= 0 && (!('hasQr' in data.identifierSummary) || data.identifierSummary.hasQr is bool) && (!('hasNfc' in data.identifierSummary) || data.identifierSummary.hasNfc is bool)))
        && (!('primaryImageUrl' in data) || (data.primaryImageUrl is string && data.primaryImageUrl.size() <= 2000));
    }

    match /objects/{objectId} {
      allow get: if isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      allow create: if isSignedIn()
        && isValidId(objectId)
        && incoming().objectId == objectId
        && isValidObjectBase(incoming())
        && incoming().keys().hasOnly(['objectId', 'ownerId', 'name', 'description', 'status', 'currentLocation', 'primaryImageId', 'primaryImageUrl', 'identifierSummary', 'legacy', 'createdAt', 'updatedAt'])
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isSignedIn()
        && isOwner(existing().ownerId)
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && isValidObjectBase(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'status', 'currentLocation', 'primaryImageId', 'primaryImageUrl', 'identifierSummary', 'updatedAt']);

      allow delete: if isOwner(existing().ownerId);
    }

    // --- IDENTIFIERS ---
    match /identifiers/{identifierKey} {
      allow get: if isSignedIn() && (existing() == null || existing().ownerId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      allow create: if isSignedIn()
        && isValidId(identifierKey)
        && incoming().identifierKey == identifierKey
        && incoming().ownerId == request.auth.uid
        && incoming().kind in ['qr', 'nfc', 'manual', 'barcode', 'bluetooth']
        && incoming().scheme is string && incoming().scheme.size() <= 1000
        && incoming().canonicalValue is string && incoming().canonicalValue.size() <= 1000
        && (!('rawValue' in incoming()) || (incoming().rawValue is string && incoming().rawValue.size() <= 1000))
        && (!('label' in incoming()) || (incoming().label is string && incoming().label.size() <= 1000))
        && (!('lastSeenAt' in incoming()) || incoming().lastSeenAt is timestamp)
        && incoming().status in ['active', 'unassigned', 'retired', 'lost', 'replaced']
        && (incoming().status in ['unassigned', 'retired', 'lost', 'replaced'] || ('objectId' in incoming() && incoming().objectId is string && incoming().objectId.size() <= 128))
        && incoming().keys().hasOnly(['identifierKey', 'ownerId', 'objectId', 'kind', 'scheme', 'canonicalValue', 'rawValue', 'label', 'status', 'createdAt', 'updatedAt', 'lastSeenAt'])
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isSignedIn()
        && isOwner(existing().ownerId)
        && incoming().identifierKey == identifierKey
        && incoming().ownerId == existing().ownerId
        && incoming().kind == existing().kind
        && incoming().scheme == existing().scheme
        && incoming().canonicalValue == existing().canonicalValue
        && (!('rawValue' in incoming()) || (incoming().rawValue is string && incoming().rawValue.size() <= 1000))
        && (!('label' in incoming()) || (incoming().label is string && incoming().label.size() <= 1000))
        && (!('lastSeenAt' in incoming()) || incoming().lastSeenAt is timestamp)
        && incoming().status in ['active', 'unassigned', 'retired', 'lost', 'replaced']
        && (incoming().status in ['unassigned', 'retired', 'lost', 'replaced'] || ('objectId' in incoming() && incoming().objectId is string && incoming().objectId.size() <= 128))
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['objectId', 'status', 'label', 'rawValue', 'updatedAt', 'lastSeenAt']);

      allow delete: if isOwner(existing().ownerId);
    }

    // --- OBJECT IDENTIFIER BINDINGS ---
    match /objectIdentifierBindings/{bindingId} {
      allow read: if isOwner(existing().ownerId);
      allow create: if isSignedIn()
        && incoming().bindingId == bindingId
        && incoming().ownerId == request.auth.uid
        && incoming().objectId is string
        && incoming().identifierKey is string
        && incoming().status in ['active', 'detached', 'replaced']
        && incoming().attachedAt is timestamp
        && incoming().attachedBy is string
        && (incoming().status == 'active' || ('detachedAt' in incoming() && incoming().detachedAt is timestamp && 'detachedBy' in incoming() && incoming().detachedBy is string))
        && (!('note' in incoming()) || (incoming().note is string && incoming().note.size() <= 2000))
        && incoming().keys().hasOnly(['bindingId', 'ownerId', 'objectId', 'identifierKey', 'status', 'attachedAt', 'attachedBy', 'detachedAt', 'detachedBy', 'note', 'createdAt', 'updatedAt'])
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      allow update: if isSignedIn()
        && isOwner(existing().ownerId)
        && incoming().bindingId == bindingId
        && incoming().ownerId == existing().ownerId
        && incoming().objectId == existing().objectId
        && incoming().identifierKey == existing().identifierKey
        && incoming().attachedAt == existing().attachedAt
        && incoming().attachedBy == existing().attachedBy
        && incoming().status in ['active', 'detached', 'replaced']
        && (incoming().status == 'active' || ('detachedAt' in incoming() && incoming().detachedAt is timestamp && 'detachedBy' in incoming() && incoming().detachedBy is string))
        && (!('note' in incoming()) || (incoming().note is string && incoming().note.size() <= 2000))
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'detachedAt', 'detachedBy', 'note', 'updatedAt']);
    }

    // --- OBJECT EVENTS ---
    match /objectEvents/{eventId} {
      allow read: if isOwner(existing().ownerId);
      allow create: if isSignedIn()
        && incoming().eventId == eventId
        && incoming().ownerId == request.auth.uid
        && (!('objectId' in incoming()) || (incoming().objectId is string && incoming().objectId.size() <= 128))
        && (!('identifierKey' in incoming()) || (incoming().identifierKey is string && incoming().identifierKey.size() <= 128))
        && incoming().actorUid == request.auth.uid
        && incoming().occurredAt == request.time
        && incoming().type in ['created', 'updated', 'scanned', 'located', 'image_added', 'image_removed', 'identifier_attached', 'identifier_detached', 'identifier_replaced', 'migrated']
        && (!('source' in incoming()) || incoming().source in ['qr', 'nfc', 'manual', 'camera', 'system', 'migration'])
        && (!('location' in incoming()) || (incoming().location is map && 'latitude' in incoming().location && incoming().location.latitude is number && incoming().location.latitude >= -90 && incoming().location.latitude <= 90 && 'longitude' in incoming().location && incoming().location.longitude is number && incoming().location.longitude >= -180 && incoming().location.longitude <= 180 && (!('address' in incoming().location) || (incoming().location.address is string && incoming().location.address.size() <= 1000))))
        && (!('metadata' in incoming()) || incoming().metadata is map)
        && incoming().keys().hasOnly(['eventId', 'ownerId', 'objectId', 'identifierKey', 'type', 'occurredAt', 'actorUid', 'source', 'location', 'metadata']);
      // Append only by default, but allow updates if needed for some logic (mostly no).
      allow update, delete: if isAdmin();
    }

    // --- OBJECT IMAGES ---
    match /objectImages/{imageId} {
      allow read: if isOwner(existing().ownerId);
      allow create: if isSignedIn()
        && incoming().imageId == imageId
        && incoming().ownerId == request.auth.uid
        && incoming().objectId is string && incoming().objectId.size() <= 128
        && incoming().role in ['primary', 'context', 'label', 'detail']
        && (('storagePath' in incoming() && incoming().storagePath is string && incoming().storagePath.size() <= 1000) || ('downloadUrl' in incoming() && incoming().downloadUrl is string && incoming().downloadUrl.size() <= 1000))
        && (!('contentType' in incoming()) || (incoming().contentType is string && incoming().contentType.size() <= 100))
        && (!('sizeBytes' in incoming()) || incoming().sizeBytes is number)
        && (!('width' in incoming()) || incoming().width is number)
        && (!('height' in incoming()) || incoming().height is number)
        && (!('sortOrder' in incoming()) || incoming().sortOrder is number)
        && (!('legacy' in incoming()) || incoming().legacy is map)
        && incoming().keys().hasOnly(['imageId', 'ownerId', 'objectId', 'role', 'storagePath', 'downloadUrl', 'contentType', 'sizeBytes', 'width', 'height', 'sortOrder', 'createdAt', 'createdBy', 'legacy'])
        && incoming().createdAt == request.time
        && incoming().createdBy == request.auth.uid;
      allow update: if isSignedIn()
        && isOwner(existing().ownerId)
        && incoming().imageId == imageId
        && incoming().ownerId == existing().ownerId
        && incoming().objectId == existing().objectId
        && incoming().createdAt == existing().createdAt
        && incoming().createdBy == existing().createdBy
        && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'storagePath', 'downloadUrl', 'contentType', 'sizeBytes', 'width', 'height', 'sortOrder']);
      allow delete: if isOwner(existing().ownerId);
    }

    // --- LEGACY ITEMS (Read-only or admin for migration, or owner for backward compat) ---
    function isValidItemBase(data) {
      return data.keys().hasAll(['id', 'ownerId', 'createdAt', 'updatedAt'])
        && data.id is string && data.id.size() <= 1024
        && data.ownerId == request.auth.uid
        && (data.get('name', '') is string && data.get('name', '').size() <= 200)
        && (data.get('description', '') is string && data.get('description', '').size() <= 2000)
        && (data.get('mainImageUrl', '') is string && data.get('mainImageUrl', '').size() <= 1000)
        && (data.get('contextImageUrls', []) is list && data.get('contextImageUrls', []).size() <= 10)
        && (data.get('bluetoothTags', []) is list && data.get('bluetoothTags', []).size() <= 50)
        && (data.get('tagType', 'none') in ['qr', 'nfc', 'none']);
    }

    match /items/{itemId} {
      allow get: if isOwner(existing().ownerId) || isAdmin();
      allow list: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      
      allow create: if isSignedIn() 
        && isValidId(itemId)
        && isValidItemBase(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn()
        && isOwner(existing().ownerId)
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && isValidItemBase(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'mainImageUrl', 'contextImageUrls', 'bluetoothTags', 'tagType', 'updatedAt', 'location']);

      allow delete: if isOwner(existing().ownerId) || isAdmin();
    }

    // --- USER PROFILE ---
    function isValidSettings(settings) {
      return (!('imageFormat' in settings) || settings.imageFormat in ['webp', 'jpeg'])
        && (!('compressionQuality' in settings) || (settings.compressionQuality is number && settings.compressionQuality >= 0.1 && settings.compressionQuality <= 1.0))
        && (!('maxResolution' in settings) || settings.maxResolution in [512, 1024, 2048]);
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.keys().hasAll(['uid'])
        && (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100)
        && (data.get('email', '') is string && data.get('email', '').size() <= 100)
        && (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 500)
        && (data.get('role', 'user') in ['user', 'admin'])
        && (!('settings' in data) || isValidSettings(data.settings));
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && incoming().get('role', 'user') == 'user';
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && (incoming().get('role', 'user') == existing().get('role', 'user') || isAdmin());
    }

    // --- ADMINS ---
    function isValidAdmin(data) {
      return data.keys().hasAny(['grantedAt', 'grantedBy']) 
        && (!('grantedAt' in data) || data.grantedAt == request.time)
        && (!('grantedBy' in data) || data.grantedBy == request.auth.uid);
    }

    match /admins/{adminId} {
      allow read: if isAdmin() || request.auth.uid == adminId;
      allow write: if isAdmin() && isValidAdmin(incoming());
    }
  }
}
