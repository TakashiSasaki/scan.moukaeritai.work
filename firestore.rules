rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidRecordMetadata(meta) {
      return meta is map
        && meta.recordCreatedAt is timestamp
        && meta.recordUpdatedAt is timestamp
        && meta.recordCreatedBy is string
        && meta.recordUpdatedBy is string
        && meta.schemaVersion is number;
    }

    // --- OBJECTS ---
    function isValidObjectBase(data) {
      return data.keys().hasAll(['objectId', 'ownerId'])
        && data.objectId is string && data.objectId.size() <= 128
        && data.ownerId == request.auth.uid
        && (data.get('name', '') is string && data.get('name', '').size() <= 200)
        && (data.get('description', '') is string && data.get('description', '').size() <= 2000)
        && data.get('status', 'active') in ['active', 'archived', 'lost', 'disposed']
        && (!('_meta' in data) || isValidRecordMetadata(data._meta));
    }

    match /objects/{objectId} {
      allow get: if isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      allow create: if isSignedIn()
        && isValidId(objectId)
        && incoming().objectId == objectId
        && isValidObjectBase(incoming())
        && incoming().keys().hasOnly(['objectId', 'ownerId', 'name', 'description', 'status', '_meta', 'legacy'])
        && (!('_meta' in incoming()) || (incoming()._meta.recordCreatedAt == request.time && incoming()._meta.recordUpdatedAt == request.time));

      allow update: if isSignedIn()
        && isOwner(existing().ownerId)
        && incoming().ownerId == existing().ownerId
        && isValidObjectBase(incoming())
        && incoming().keys().hasOnly(['objectId', 'ownerId', 'name', 'description', 'status', '_meta', 'legacy'])
        && (!('_meta' in incoming()) || incoming()._meta.recordUpdatedAt == request.time)
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'status', '_meta', 'legacy']);

      allow delete: if isOwner(existing().ownerId);
    }

    // --- MARKERS (Target Entity) ---
    function isValidMarker(data, id) {
      return data.markerKey == id
        && data.medium in ['visual_code', 'nfc', 'rfid', 'bluetooth', 'manual', 'visual_recognition', 'unknown']
        && (!('mediumSubtype' in data) || data.mediumSubtype is string)
        && data.payloadLayer in ['encoded_payload', 'native_carrier_id', 'radio_signal', 'connected_payload', 'derived_fingerprint', 'manual_input']
        && data.payloadKind is string
        && (!('canonicalPayload' in data) || data.canonicalPayload is string)
        && data.stability in ['stable', 'semi_stable', 'rotating', 'session', 'derived', 'unknown']
        && (!('privacy' in data) || data.privacy is map)
        && (!('_meta' in data) || isValidRecordMetadata(data._meta))
        && (!('legacy' in data) || data.legacy is map);
    }

    match /markers/{markerKey} {
      allow read: if isAdmin() || isOwner(existing().ownerId);
      allow create: if isSignedIn()
        && incoming().ownerId == request.auth.uid
        && isValidMarker(incoming(), markerKey)
        && incoming().keys().hasOnly(['markerKey', 'ownerId', 'medium', 'mediumSubtype', 'payloadLayer', 'payloadKind', 'canonicalPayload', 'stability', 'privacy', '_meta', 'legacy'])
        && (!('_meta' in incoming()) || (incoming()._meta.recordCreatedAt == request.time && incoming()._meta.recordUpdatedAt == request.time));

      allow update: if isSignedIn()
        && isOwner(existing().ownerId)
        && incoming().ownerId == existing().ownerId
        && incoming().medium == existing().medium
        && incoming().payloadLayer == existing().payloadLayer
        && incoming().payloadKind == existing().payloadKind
        && isValidMarker(incoming(), markerKey)
        && incoming().keys().hasOnly(['markerKey', 'ownerId', 'medium', 'mediumSubtype', 'payloadLayer', 'payloadKind', 'canonicalPayload', 'stability', 'privacy', '_meta', 'legacy'])
        && (!('_meta' in incoming()) || incoming()._meta.recordUpdatedAt == request.time)
        && incoming().diff(existing()).affectedKeys().hasOnly(['mediumSubtype', 'canonicalPayload', 'stability', 'privacy', '_meta', 'legacy']);

      allow delete: if isAdmin() || isOwner(existing().ownerId);
    }

    // --- PLACES (Target Entity) ---
    function isValidPlace(data, id) {
      return data.placeId == id
        && (!('label' in data) || data.label is string)
        && (!('_meta' in data) || isValidRecordMetadata(data._meta))
        && (!('legacy' in data) || data.legacy is map);
    }

    match /places/{placeId} {
      allow read: if isAdmin() || isOwner(existing().ownerId);
      allow create: if isSignedIn()
        && incoming().ownerId == request.auth.uid
        && isValidPlace(incoming(), placeId)
        && incoming().keys().hasOnly(['placeId', 'ownerId', 'label', '_meta', 'legacy'])
        && (!('_meta' in incoming()) || (incoming()._meta.recordCreatedAt == request.time && incoming()._meta.recordUpdatedAt == request.time));

      allow update: if isSignedIn()
        && isOwner(existing().ownerId)
        && incoming().ownerId == existing().ownerId
        && isValidPlace(incoming(), placeId)
        && incoming().keys().hasOnly(['placeId', 'ownerId', 'label', '_meta', 'legacy'])
        && (!('_meta' in incoming()) || incoming()._meta.recordUpdatedAt == request.time)
        && incoming().diff(existing()).affectedKeys().hasOnly(['label', '_meta', 'legacy']);

      allow delete: if isAdmin() || isOwner(existing().ownerId);
    }

    // --- FACT INDEX / ACCESS CONTROL HELPERS ---

    function hasCurrentUser(data) {
      return 'userIds' in data && data.userIds is list && request.auth.uid in data.userIds;
    }

    function isLegacyOwner(data) {
      return 'legacy' in data && data.legacy is map && data.legacy.get('ownerId', '') == request.auth.uid;
    }

    function canAccessFact(data) {
      return hasCurrentUser(data) || isLegacyOwner(data);
    }

    function isValidFactIndexArrays(data) {
      return (!('objectIds' in data) || (data.objectIds is list && data.objectIds.size() <= 20))
        && (!('markerKeys' in data) || (data.markerKeys is list && data.markerKeys.size() <= 20))
        && (!('placeIds' in data) || (data.placeIds is list && data.placeIds.size() <= 20))
        && (!('readerIds' in data) || (data.readerIds is list && data.readerIds.size() <= 20))
        && (!('deviceIds' in data) || (data.deviceIds is list && data.deviceIds.size() <= 20))
        && (!('userIds' in data) || (data.userIds is list && data.userIds.size() <= 20));
    }

    function isFactEntitiesOwnedByUser(data) {
      return (!('objectIds' in data) || data.objectIds.size() == 0 || (
        data.objectIds.size() == 1 &&
        exists(/databases/$(database)/documents/objects/$(data.objectIds[0])) &&
        get(/databases/$(database)/documents/objects/$(data.objectIds[0])).data.ownerId == request.auth.uid
      )) && (!('markerKeys' in data) || data.markerKeys.size() == 0 || (
        data.markerKeys.size() == 1 &&
        exists(/databases/$(database)/documents/markers/$(data.markerKeys[0])) &&
        get(/databases/$(database)/documents/markers/$(data.markerKeys[0])).data.ownerId == request.auth.uid
      )) && (!('placeIds' in data) || data.placeIds.size() == 0 || (
        data.placeIds.size() == 1 &&
        exists(/databases/$(database)/documents/places/$(data.placeIds[0])) &&
        get(/databases/$(database)/documents/places/$(data.placeIds[0])).data.ownerId == request.auth.uid
      ));
    }

    function isValidFactParticipants(data) {
      return data.participants is list
        && data.participantKeys is list
        && data.participants.size() == data.participantKeys.size()
        && data.participants.size() <= 20;
    }

    // --- ASSOCIATIONS (Target Fact) ---
    match /associations/{associationId} {
      allow read: if isAdmin() || (isSignedIn() && canAccessFact(existing()));
      allow create: if isSignedIn()
        && incoming().associationId == associationId
        && canAccessFact(incoming())
        && incoming().associationType is string
        && isValidFactParticipants(incoming())
        && isValidFactIndexArrays(incoming())
        && isFactEntitiesOwnedByUser(incoming())
        && incoming().time is map
        && incoming().time.keys().hasOnly(['validFrom', 'validUntil'])
        && (!('validFrom' in incoming().time) || incoming().time.validFrom is timestamp)
        && (!('validUntil' in incoming().time) || incoming().time.validUntil is timestamp)
        && (!('status' in incoming()) || incoming().status in ['active', 'detached', 'superseded', 'replaced'])
        && (!('provenance' in incoming()) || incoming().provenance is map)
        && (!('note' in incoming()) || incoming().note is string)
        && (!('_meta' in incoming()) || isValidRecordMetadata(incoming()._meta))
        && (!('legacy' in incoming()) || incoming().legacy is map)
        && incoming().keys().hasOnly(['associationId', 'associationType', 'participants', 'participantKeys', 'objectIds', 'markerKeys', 'placeIds', 'readerIds', 'deviceIds', 'userIds', 'time', 'provenance', 'status', 'note', '_meta', 'legacy']);
      allow update: if false; // Append-only
      allow delete: if false; // Append-only
    }

    // --- OBSERVATIONS (Target Fact) ---
    match /observations/{observationId} {
      allow read: if isAdmin() || (isSignedIn() && canAccessFact(existing()));
      allow create: if isSignedIn()
        && incoming().observationId == observationId
        && canAccessFact(incoming())
        && incoming().observationType is string
        && isValidFactParticipants(incoming())
        && isValidFactIndexArrays(incoming())
        && isFactEntitiesOwnedByUser(incoming())
        && incoming().time is map
        && incoming().time.keys().hasOnly(['observedAt', 'receivedAt'])
        && incoming().time.observedAt is timestamp
        && (!('receivedAt' in incoming().time) || incoming().time.receivedAt is timestamp)
        && (!('provenance' in incoming()) || incoming().provenance is map)
        && (!('payload' in incoming()) || incoming().payload is map)
        && (!('note' in incoming()) || incoming().note is string)
        && (!('_meta' in incoming()) || isValidRecordMetadata(incoming()._meta))
        && (!('legacy' in incoming()) || incoming().legacy is map)
        && incoming().keys().hasOnly(['observationId', 'observationType', 'participants', 'participantKeys', 'objectIds', 'markerKeys', 'placeIds', 'readerIds', 'deviceIds', 'userIds', 'time', 'provenance', 'payload', 'note', '_meta', 'legacy']);
      allow update: if false; // Append-only
      allow delete: if false; // Append-only
    }

    // --- MEASUREMENTS (Target Fact) ---
    match /measurements/{measurementId} {
      allow read: if isAdmin() || (isSignedIn() && canAccessFact(existing()));
      allow create: if isSignedIn()
        && incoming().measurementId == measurementId
        && canAccessFact(incoming())
        && incoming().measurementType is string
        && isValidFactParticipants(incoming())
        && isValidFactIndexArrays(incoming())
        && isFactEntitiesOwnedByUser(incoming())
        && incoming().time is map
        && incoming().time.keys().hasOnly(['measuredAt', 'receivedAt'])
        && incoming().time.measuredAt is timestamp
        && (!('receivedAt' in incoming().time) || incoming().time.receivedAt is timestamp)
        && (!('position' in incoming()) || (incoming().position is map && incoming().position.latitude is number && incoming().position.longitude is number))
        && (!('place' in incoming()) || incoming().place is map)
        && (!('signal' in incoming()) || incoming().signal is map)
        && (!('provenance' in incoming()) || incoming().provenance is map)
        && (!('note' in incoming()) || incoming().note is string)
        && (!('_meta' in incoming()) || isValidRecordMetadata(incoming()._meta))
        && (!('legacy' in incoming()) || incoming().legacy is map)
        && incoming().keys().hasOnly(['measurementId', 'measurementType', 'participants', 'participantKeys', 'objectIds', 'markerKeys', 'placeIds', 'readerIds', 'deviceIds', 'userIds', 'time', 'provenance', 'position', 'place', 'signal', 'note', '_meta', 'legacy']);
      allow update: if false; // Append-only
      allow delete: if false; // Append-only
    }

    // --- EVENTS (Target Fact) ---
    match /events/{eventId} {
      allow read: if isAdmin() || (isSignedIn() && canAccessFact(existing()));
      allow create: if isSignedIn()
        && incoming().eventId == eventId
        && canAccessFact(incoming())
        && incoming().eventType is string
        && isValidFactParticipants(incoming())
        && isValidFactIndexArrays(incoming())
        && isFactEntitiesOwnedByUser(incoming())
        && incoming().time is map
        && incoming().time.keys().hasOnly(['occurredAt', 'receivedAt'])
        && incoming().time.occurredAt is timestamp
        && (!('receivedAt' in incoming().time) || incoming().time.receivedAt is timestamp)
        && (!('provenance' in incoming()) || incoming().provenance is map)
        && (!('note' in incoming()) || incoming().note is string)
        && (!('_meta' in incoming()) || isValidRecordMetadata(incoming()._meta))
        && (!('legacy' in incoming()) || incoming().legacy is map)
        && incoming().keys().hasOnly(['eventId', 'eventType', 'participants', 'participantKeys', 'objectIds', 'markerKeys', 'placeIds', 'readerIds', 'deviceIds', 'userIds', 'time', 'provenance', 'note', '_meta', 'legacy']);
      allow update: if false; // Append-only
      allow delete: if false; // Append-only
    }

    // --- PROJECTIONS (Derived Summaries) ---
    match /objectSummaries/{objectId} {
      allow read: if isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/objects/$(objectId)) && get(/databases/$(database)/documents/objects/$(objectId)).data.ownerId == request.auth.uid);
      allow create, update, delete: if false; // Projections are read-only to clients, updated via Admin SDK/Functions
    }

    match /markerSummaries/{markerKey} {
      allow read: if isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/markers/$(markerKey)) && get(/databases/$(database)/documents/markers/$(markerKey)).data.ownerId == request.auth.uid);
      allow create, update, delete: if false; // Projections are read-only to clients
    }

    match /placeSummaries/{placeId} {
      allow read: if isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/places/$(placeId)) && get(/databases/$(database)/documents/places/$(placeId)).data.ownerId == request.auth.uid);
      allow create, update, delete: if false; // Projections are read-only to clients
    }

    // --- USER PROFILE ---
    function isValidSettings(settings) {
      return (!('imageFormat' in settings) || settings.imageFormat in ['webp', 'jpeg'])
        && (!('compressionQuality' in settings) || (settings.compressionQuality is number && settings.compressionQuality >= 0.1 && settings.compressionQuality <= 1.0))
        && (!('maxResolution' in settings) || settings.maxResolution in [512, 1024, 2048]);
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.keys().hasAll(['uid'])
        && (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100)
        && (data.get('email', '') is string && data.get('email', '').size() <= 100)
        && (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 500)
        && (data.get('role', 'user') in ['user', 'admin'])
        && (!('settings' in data) || isValidSettings(data.settings));
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && incoming().get('role', 'user') == 'user';
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && (incoming().get('role', 'user') == existing().get('role', 'user') || isAdmin());
    }

    // --- ADMINS ---
    function isValidAdmin(data) {
      return data.keys().hasAny(['grantedAt', 'grantedBy']) 
        && (!('grantedAt' in data) || data.grantedAt == request.time)
        && (!('grantedBy' in data) || data.grantedBy == request.auth.uid);
    }

    match /admins/{adminId} {
      allow read: if isAdmin() || request.auth.uid == adminId;
      allow write: if isAdmin() && isValidAdmin(incoming());
    }

    // --- RECIPIENTS OF LEGACY/MIGRATION BLOCKS (Locked for Client Write) ---
    match /items/{itemId} {
      allow get: if isOwner(existing().ownerId) || isAdmin();
      allow list: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create, update, delete: if false;
    }

    match /identifiers/{identifierKey} {
      allow get: if isSignedIn() && (existing() == null || existing().ownerId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /identifierObservations/{observationId} {
      allow read: if isSignedIn() && (existing().get('ownerId', null) == request.auth.uid || existing().get('observerUid', null) == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /objectIdentifierBindings/{bindingId} {
      allow read: if isOwner(existing().ownerId);
      allow create, update, delete: if false;
    }

    match /objectEvents/{eventId} {
      allow read: if isOwner(existing().ownerId);
      allow create, update, delete: if false;
    }

    match /objectImages/{imageId} {
      allow read: if isOwner(existing().ownerId);
      allow create, update, delete: if false;
    }
  }
}
