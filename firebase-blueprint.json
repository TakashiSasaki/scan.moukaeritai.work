{
  "entities": {
    "ObjectRecord": {
      "title": "Object Record",
      "description": "Represents a real-world physical object being cataloged.",
      "type": "object",
      "properties": {
        "objectId": {
          "type": "string",
          "description": "The unique ID matching the document ID."
        },
        "name": {
          "description": "Short name of the object.",
          "type": "string"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the object."
        },
        "ownerId": {
          "type": "string",
          "description": "UID of the user who owns this object."
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "archived",
            "lost",
            "disposed"
          ]
        },
        "currentLocation": {
          "type": "object",
          "description": "Geographical location (latitude/longitude/address).",
          "properties": {
            "latitude": {
              "type": "number"
            },
            "longitude": {
              "type": "number"
            },
            "address": {
              "type": "string"
            },
            "updatedAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "primaryImageId": {
          "type": "string",
          "description": "ID of the primary image."
        },
        "identifierSummary": {
          "type": "object",
          "description": "Denormalized UI summary.",
          "properties": {
            "activeKinds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "activeIdentifierCount": {
              "type": "number"
            },
            "hasQr": {
              "type": "boolean"
            },
            "hasNfc": {
              "type": "boolean"
            }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "primaryImageUrl": {
          "type": "string",
          "description": "Denormalized URL for fast list view rendering."
        },
        "legacy": {
          "type": "object",
          "properties": {
            "sourceCollection": {
              "type": "string",
              "enum": [
                "items"
              ]
            },
            "legacyItemId": {
              "type": "string"
            }
          }
        }
      },
      "required": [
        "objectId",
        "ownerId",
        "status",
        "createdAt",
        "updatedAt"
      ]
    },
    "IdentifierRecord": {
      "title": "Identifier Record",
      "description": "Lookup table from a scanned QR/NFC/manual value to an object.",
      "type": "object",
      "properties": {
        "identifierKey": {
          "type": "string",
          "description": "Normalized Firestore-safe ID."
        },
        "ownerId": {
          "type": "string",
          "description": "UID of the user who owns this identifier."
        },
        "objectId": {
          "type": "string",
          "description": "Optional object this identifier resolves to."
        },
        "kind": {
          "type": "string",
          "enum": [
            "qr",
            "nfc",
            "manual",
            "barcode",
            "bluetooth"
          ]
        },
        "scheme": {
          "type": "string",
          "description": "e.g., qr-url-token, nfc-uid"
        },
        "canonicalValue": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "unassigned",
            "retired",
            "lost",
            "replaced"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "rawValue": {
          "type": "string",
          "description": "Original raw scanned value."
        },
        "label": {
          "type": "string",
          "description": "Optional human-readable label."
        },
        "lastSeenAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "identifierKey",
        "ownerId",
        "kind",
        "scheme",
        "canonicalValue",
        "status",
        "createdAt",
        "updatedAt"
      ]
    },
    "ObjectIdentifierBindingRecord": {
      "title": "Object Identifier Binding Record",
      "description": "Canonical active relationship state linking an object to an identifier. This is NOT an append-only historical log; use objectEvents for history.",
      "type": "object",
      "properties": {
        "bindingId": {
          "type": "string",
          "description": "Deterministic active ID formatted as ${objectId}__${identifierKey}__active to prevent duplicate active bindings"
        },
        "ownerId": {
          "type": "string"
        },
        "objectId": {
          "type": "string"
        },
        "identifierKey": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "detached",
            "replaced"
          ]
        },
        "attachedAt": {
          "type": "string",
          "format": "date-time"
        },
        "attachedBy": {
          "type": "string"
        },
        "detachedAt": {
          "type": "string",
          "format": "date-time"
        },
        "detachedBy": {
          "type": "string"
        },
        "note": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "bindingId",
        "ownerId",
        "objectId",
        "identifierKey",
        "status",
        "attachedAt",
        "attachedBy"
      ]
    },
    "ObjectEventRecord": {
      "title": "Object Event Record",
      "description": "Append-only event log for inventory operations.",
      "type": "object",
      "properties": {
        "eventId": {
          "type": "string"
        },
        "ownerId": {
          "type": "string"
        },
        "objectId": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "created",
            "updated",
            "scanned",
            "located",
            "image_added",
            "image_removed",
            "identifier_attached",
            "identifier_detached",
            "identifier_replaced",
            "migrated"
          ]
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "actorUid": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "qr",
            "nfc",
            "manual",
            "camera",
            "system",
            "migration"
          ]
        },
        "location": {
          "type": "object"
        },
        "metadata": {
          "type": "object"
        }
      },
      "required": [
        "eventId",
        "ownerId",
        "type",
        "occurredAt",
        "actorUid"
      ]
    },
    "ObjectImageRecord": {
      "title": "Object Image Record",
      "description": "Represents images stored in Firebase Storage.",
      "type": "object",
      "properties": {
        "imageId": {
          "type": "string"
        },
        "ownerId": {
          "type": "string"
        },
        "objectId": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "primary",
            "context",
            "label",
            "detail"
          ]
        },
        "storagePath": {
          "type": "string"
        },
        "downloadUrl": {
          "type": "string"
        },
        "contentType": {
          "type": "string"
        },
        "sizeBytes": {
          "type": "number"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "sortOrder": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "createdBy": {
          "type": "string"
        },
        "legacy": {
          "type": "object",
          "properties": {
            "sourceField": {
              "type": "string",
              "enum": [
                "mainImageUrl",
                "contextImageUrls"
              ]
            },
            "sourceUrl": {
              "type": "string"
            }
          }
        }
      },
      "required": [
        "imageId",
        "ownerId",
        "objectId",
        "role"
      ]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "photoURL": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "user",
            "admin"
          ],
          "description": "User role, usually not set by user directly."
        },
        "settings": {
          "type": "object",
          "description": "User specific settings including image capture preferences.",
          "properties": {
            "imageFormat": {
              "type": "string",
              "enum": [
                "webp",
                "jpeg"
              ]
            },
            "compressionQuality": {
              "type": "number",
              "minimum": 0.1,
              "maximum": 1
            },
            "maxResolution": {
              "type": "number",
              "enum": [
                512,
                1024,
                2048
              ]
            }
          }
        }
      },
      "required": [
        "uid"
      ]
    },
    "Admin": {
      "title": "Admin",
      "description": "Record to identify admin users securely.",
      "type": "object",
      "properties": {
        "grantedAt": {
          "type": "string",
          "format": "date-time"
        },
        "grantedBy": {
          "type": "string",
          "description": "UID of the user who granted this admin right"
        }
      }
    }
  },
  "firestore": {
    "/objects/{objectId}": {
      "schema": "ObjectRecord",
      "description": "Collection of normalized tracked real-world objects."
    },
    "/identifiers/{identifierKey}": {
      "schema": "IdentifierRecord",
      "description": "Lookup table from scanned values to objects."
    },
    "/objectIdentifierBindings/{bindingId}": {
      "schema": "ObjectIdentifierBindingRecord",
      "description": "Canonical relationship state between objects and identifiers."
    },
    "/objectEvents/{eventId}": {
      "schema": "ObjectEventRecord",
      "description": "Append-only event log."
    },
    "/objectImages/{imageId}": {
      "schema": "ObjectImageRecord",
      "description": "Storage metadata for images."
    },
    "/items/{itemId}": {
      "schema": "LegacyItem",
      "description": "Legacy collection retained only for migration and backward compatibility."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "List of administrative users to enable RBAC."
    }
  }
}
