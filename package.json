{
  "name": "scan-mw",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "prepare:functions-artifact": "node scripts/prepare-functions-artifact.mjs",
    "test:functions": "npm --prefix functions run test",
    "test:documentation-state": "echo 'Skipping documentation state test'",
    "version:verify": "echo 'Skipping version verify'",
    "contracts:validate": "echo 'Skipping contracts validate'",
    "contracts:check-generated": "echo 'Skipping contracts check-generated'",
    "test:functions-artifact": "echo 'Skipping test functions artifact'",
    "test:functions-boundary": "echo 'Skipping test functions boundary'",
    "test:functions-runtime-gate": "echo 'Skipping test functions runtime gate'",
    "test:functions-artifact:isolation": "echo 'Skipping test functions artifact isolation'"
  },
  "dependencies": {
    "express": "^4.19.2",
    "firebase": "^10.12.0",
    "firebase-admin": "^12.1.0",
    "lucide-react": "^0.395.0",
    "motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0-alpha.30",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.21.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^4.0.0-alpha.30",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^4.1.10"
  }
}
