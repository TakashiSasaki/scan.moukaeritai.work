{
  "name": "scan-mw",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:routing": "vitest run tests/routing/",
    "test:routing-boundary": "node scripts/test-routing-boundary.mjs",
    "test:functions": "npm --prefix functions run test",
    "test:firestore-policy": "node scripts/test-firestore-policy.mjs",
    "test:documentation-state": "node scripts/validate-documentation-state.mjs",
    "contracts:validate": "node scripts/validate-contracts.mjs",
    "contracts:check-generated": "node scripts/check-generated-types.mjs",
    "prepare:functions-artifact": "node scripts/prepare-functions-artifact.mjs",
    "test:functions-artifact": "node scripts/test-functions-artifact.mjs",
    "test:functions-boundary": "node scripts/validate-functions-import-boundary.mjs",
    "test:functions-runtime-gate": "node scripts/validate-functions-runtime-gate.mjs",
    "test:functions-artifact:isolation": "node scripts/validate-local-artifact-path.mjs",
    "verify:fast": "node scripts/verify-fast.mjs",
    "verify:pr": "node scripts/validate-repository-bootstrap.mjs && node scripts/validate-documentation-state.mjs && node scripts/verify-version.mjs --static && npm run contracts:validate && npm run contracts:check-generated && npm run test:firestore-policy && npm run test:routing && npm run test && npm run lint && npm run build && npm --prefix packages/efp-model run build && npm --prefix packages/efp-model run typecheck && npm --prefix packages/efp-model run test && npm run prepare:functions-artifact && npm ci --prefix functions && npm --prefix functions run build && npm --prefix functions run test && npm run test:functions-artifact && npm run test:functions-boundary",
    "verify:release": "npm run verify:pr && node scripts/verify-version.mjs --static",
    "version:verify": "node scripts/verify-version.mjs --static"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "express": "^4.19.2",
    "firebase": "^10.12.0",
    "firebase-admin": "^12.1.0",
    "lucide-react": "^0.395.0",
    "motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.23.0",
    "tailwind-merge": "^2.3.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0-alpha.30",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.21.3",
    "html5-qrcode": "^2.3.8",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^4.0.0-alpha.30",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^4.1.10"
  }
}
