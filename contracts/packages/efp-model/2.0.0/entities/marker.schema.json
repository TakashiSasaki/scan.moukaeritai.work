{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MarkerEntity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "markerKey",
    "medium",
    "payloadLayer",
    "payloadKind",
    "stability"
  ],
  "properties": {
    "markerKey": {
      "type": "string",
      "maxLength": 128
    },
    "ownerId": {
      "type": "string",
      "maxLength": 128
    },
    "medium": {
      "type": "string",
      "enum": [
        "visual_code",
        "nfc",
        "rfid",
        "bluetooth",
        "manual",
        "visual_recognition",
        "unknown"
      ]
    },
    "mediumSubtype": {
      "type": "string",
      "maxLength": 64
    },
    "payloadLayer": {
      "type": "string",
      "enum": [
        "encoded_payload",
        "native_carrier_id",
        "radio_signal",
        "connected_payload",
        "derived_fingerprint",
        "manual_input"
      ]
    },
    "payloadKind": {
      "type": "string",
      "maxLength": 64
    },
    "canonicalPayload": {
      "type": "string",
      "maxLength": 2048
    },
    "stability": {
      "type": "string",
      "enum": [
        "stable",
        "semi_stable",
        "rotating",
        "session",
        "derived",
        "unknown"
      ]
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trackingSensitive",
        "userConsentRequired",
        "allowBackgroundObservation"
      ],
      "properties": {
        "trackingSensitive": { "type": "boolean" },
        "userConsentRequired": { "type": "boolean" },
        "allowBackgroundObservation": { "type": "boolean" }
      }
    },
    "_meta": {
      "$ref": "../common/record-metadata.schema.json"
    }
  }
}
