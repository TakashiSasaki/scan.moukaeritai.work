{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MeasurementFact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "measurementId",
    "participants",
    "measurementType",
    "time"
  ],
  "properties": {
    "measurementId": {
      "type": "string",
      "maxLength": 128
    },
    "participants": {
      "type": "array",
      "items": {
        "$ref": "../common/participant.schema.json"
      }
    },
    "measurementType": {
      "type": "string",
      "maxLength": 64
    },
    "time": {
      "type": "object",
      "additionalProperties": false,
      "required": ["measuredAt"],
      "properties": {
        "measuredAt": { "type": "string", "format": "date-time" },
        "receivedAt": { "type": "string", "format": "date-time" }
      }
    },
    "provenance": {
      "$ref": "../common/provenance.schema.json"
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["latitude", "longitude"],
      "properties": {
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "altitude": { "type": "number" },
        "accuracyMeters": { "type": "number" }
      }
    },
    "place": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "placeId": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rssi": { "type": "number" },
        "txPower": { "type": "number" },
        "distanceEstimateMeters": { "type": "number" },
        "protocol": { "type": "string" },
        "readerId": { "type": "string" },
        "antennaId": { "type": "string" },
        "gatewayId": { "type": "string" }
      }
    },
    "note": {
      "type": "string",
      "maxLength": 1024
    },
    "_meta": {
      "$ref": "../common/record-metadata.schema.json"
    }
  }
}
