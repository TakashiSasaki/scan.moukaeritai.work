{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ObjectEntity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "objectId",
    "ownerId",
    "_meta"
  ],
  "properties": {
    "objectId": {
      "type": "string",
      "maxLength": 128,
      "description": "Unique identifier of the Object entity (UUIDv7)"
    },
    "ownerId": {
      "type": "string",
      "maxLength": 128,
      "description": "Owner identifier (UID). Note: ownerId is an administrative property and is NOT part of the object semantic identity."
    },
    "name": {
      "type": "string",
      "maxLength": 256
    },
    "description": {
      "type": "string",
      "maxLength": 1024
    },
    "status": {
      "type": "string",
      "maxLength": 64
    },
    "_meta": {
      "$ref": "../common/record-metadata.schema.json"
    }
  }
}
