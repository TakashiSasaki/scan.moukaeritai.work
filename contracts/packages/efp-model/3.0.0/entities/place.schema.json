{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PlaceEntity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "placeId",
    "ownerId",
    "_meta"
  ],
  "properties": {
    "placeId": {
      "type": "string",
      "maxLength": 128,
      "description": "Unique identifier of the Place entity (UUIDv7)"
    },
    "ownerId": {
      "type": "string",
      "maxLength": 128,
      "description": "Owner identifier (UID). Note: ownerId is an administrative property and is NOT part of the place semantic identity."
    },
    "label": {
      "type": "string",
      "maxLength": 256
    },
    "_meta": {
      "$ref": "../common/record-metadata.schema.json"
    }
  }
}
