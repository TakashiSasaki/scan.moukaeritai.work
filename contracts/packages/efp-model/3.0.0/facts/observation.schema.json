{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ObservationFact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "observationId",
    "ownerId",
    "participants",
    "participantKeys",
    "objectIds",
    "markerKeys",
    "placeIds",
    "readerIds",
    "deviceIds",
    "userIds",
    "observationType",
    "time",
    "provenance",
    "_meta"
  ],
  "properties": {
    "observationId": {
      "type": "string",
      "maxLength": 128,
      "description": "Unique identifier of the Observation fact (UUIDv7)"
    },
    "ownerId": {
      "type": "string",
      "maxLength": 128,
      "description": "Owner identifier (UID)"
    },
    "participants": {
      "type": "array",
      "items": {
        "$ref": "../common/participant.schema.json"
      }
    },
    "participantKeys": {
      "type": "array",
      "items": { "type": "string" }
    },
    "objectIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "markerKeys": {
      "type": "array",
      "items": { "type": "string" }
    },
    "placeIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "readerIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "deviceIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "userIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "observationType": {
      "type": "string",
      "maxLength": 64
    },
    "time": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observedAt"],
      "properties": {
        "observedAt": { "type": "string", "format": "date-time" },
        "receivedAt": { "type": "string", "format": "date-time" }
      }
    },
    "provenance": {
      "$ref": "../common/provenance.schema.json"
    },
    "source": {
      "type": "string",
      "maxLength": 128
    },
    "note": {
      "type": "string",
      "maxLength": 1024
    },
    "payload": {
      "type": "object"
    },
    "_meta": {
      "$ref": "../common/record-metadata.schema.json"
    }
  }
}
