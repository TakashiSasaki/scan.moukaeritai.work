{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventCommandData",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventType", "time", "provenance", "participants"],
  "properties": {
    "eventType": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "time": {
      "type": "object",
      "additionalProperties": false,
      "required": ["occurredAt"],
      "properties": {
        "occurredAt": { "type": "string", "format": "date-time" },
        "receivedAt": { "type": "string", "format": "date-time" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "confidence"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["user_confirmed", "user_report", "marker_observation", "location_measurement", "trusted_reader", "system_inference", "admin_import", "migration", "import"]
        },
        "confidence": {
          "type": "string",
          "enum": ["confirmed", "high", "medium", "low", "unknown"]
        },
        "actorUid": {
          "type": "string",
          "maxLength": 128
        }
      }
    },
    "participants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "ref"],
        "properties": {
          "role": { "type": "string", "minLength": 1, "maxLength": 128 },
          "ref": {
            "type": "object",
            "additionalProperties": false,
            "required": ["entityType", "id"],
            "properties": {
              "entityType": { "type": "string", "enum": ["object", "marker", "place", "device", "reader", "user"] },
              "id": { "type": "string", "minLength": 1, "maxLength": 128 }
            }
          }
        }
      }
    },
    "note": {
      "type": "string",
      "maxLength": 1024
    }
  }
}
