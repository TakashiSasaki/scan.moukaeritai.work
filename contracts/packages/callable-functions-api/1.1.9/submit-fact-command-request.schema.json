{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SubmitFactCommandRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "commandId",
    "factType",
    "data"
  ],
  "properties": {
    "commandId": {
      "type": "string",
      "maxLength": 128,
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "factType": {
      "type": "string",
      "enum": [
        "association",
        "observation",
        "measurement",
        "event"
      ]
    },
    "data": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "factType": {
            "const": "association"
          }
        }
      },
      "then": {
        "properties": {
          "data": {
            "$ref": "association-command-data.schema.json#"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "factType": {
            "const": "observation"
          }
        }
      },
      "then": {
        "properties": {
          "data": {
            "$ref": "observation-command-data.schema.json#"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "factType": {
            "const": "measurement"
          }
        }
      },
      "then": {
        "properties": {
          "data": {
            "$ref": "measurement-command-data.schema.json#"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "factType": {
            "const": "event"
          }
        }
      },
      "then": {
        "properties": {
          "data": {
            "$ref": "event-command-data.schema.json#"
          }
        }
      }
    }
  ]
}
