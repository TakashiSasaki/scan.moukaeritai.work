{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SubmitFactCommandRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["commandId", "factType", "data"],
  "properties": {
    "commandId": {
      "type": "string",
      "maxLength": 128,
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "factType": {
      "type": "string",
      "enum": ["association", "observation", "measurement", "event"]
    },
    "data": {
      "type": "object"
    }
  }
}
