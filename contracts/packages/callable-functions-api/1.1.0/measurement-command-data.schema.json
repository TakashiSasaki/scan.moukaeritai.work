{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MeasurementCommandData",
  "type": "object",
  "additionalProperties": false,
  "required": ["measurementType", "time", "provenance", "participants"],
  "properties": {
    "measurementType": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "time": {
      "type": "object",
      "additionalProperties": false,
      "required": ["measuredAt"],
      "properties": {
        "measuredAt": { "type": "string", "format": "date-time" },
        "receivedAt": { "type": "string", "format": "date-time" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "confidence"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["user_confirmed", "user_report", "marker_observation", "location_measurement", "trusted_reader", "system_inference", "admin_import", "migration", "import"]
        },
        "confidence": {
          "type": "string",
          "enum": ["confirmed", "high", "medium", "low", "unknown"]
        },
        "actorUid": {
          "type": "string",
          "maxLength": 128
        }
      }
    },
    "participants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "ref"],
        "properties": {
          "role": { "type": "string", "minLength": 1, "maxLength": 128 },
          "ref": {
            "type": "object",
            "additionalProperties": false,
            "required": ["entityType", "id"],
            "properties": {
              "entityType": { "type": "string", "enum": ["object", "marker", "place", "device", "reader", "user"] },
              "id": { "type": "string", "minLength": 1, "maxLength": 128 }
            }
          }
        }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["latitude", "longitude"],
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "altitude": { "type": "number" },
        "accuracyMeters": { "type": "number", "minimum": 0 }
      }
    },
    "place": {
      "type": "object",
      "additionalProperties": true
    },
    "signal": {
      "type": "object",
      "additionalProperties": true
    },
    "note": {
      "type": "string",
      "maxLength": 1024
    }
  }
}
