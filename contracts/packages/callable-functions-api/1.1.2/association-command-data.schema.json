{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AssociationCommandData",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "operation",
    "effectiveAt",
    "participants"
  ],
  "properties": {
    "operation": {
      "type": "string",
      "enum": [
        "attach",
        "detach",
        "replace"
      ]
    },
    "effectiveAt": {
      "type": "string",
      "format": "date-time"
    },
    "subjectAssociationId": {
      "type": "string",
      "maxLength": 128
    },
    "participants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "ref"
        ],
        "properties": {
          "role": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "ref": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "entityType",
              "id"
            ],
            "properties": {
              "entityType": {
                "type": "string",
                "enum": [
                  "object",
                  "marker",
                  "place",
                  "device",
                  "reader",
                  "user"
                ]
              },
              "id": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              }
            }
          }
        }
      }
    },
    "note": {
      "type": "string",
      "maxLength": 1024
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "confidence"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "user_confirmed",
            "user_report",
            "marker_observation",
            "location_measurement",
            "trusted_reader",
            "system_inference",
            "admin_import",
            "migration",
            "import"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "confirmed",
            "high",
            "medium",
            "low",
            "unknown"
          ]
        },
        "actorUid": {
          "type": "string",
          "maxLength": 128
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "operation": {
            "const": "attach"
          }
        }
      },
      "then": {
        "not": {
          "required": [
            "subjectAssociationId"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "const": "detach"
          }
        }
      },
      "then": {
        "required": [
          "subjectAssociationId"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "const": "replace"
          }
        }
      },
      "then": {
        "required": [
          "subjectAssociationId"
        ]
      }
    }
  ]
}